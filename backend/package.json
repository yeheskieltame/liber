{
  "name": "liber-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "NODE_OPTIONS=--env-file-if-exists=.env tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "node --env-file-if-exists=.env --import tsx --test $(find src -name '*.test.ts')",
    "typecheck": "tsc --noEmit",
    "migrate": "NODE_OPTIONS=--env-file-if-exists=.env tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@stellar/stellar-sdk": "^13.0.0",
    "big.js": "^6.2.1",
    "hono": "^4.6.0",
    "pg": "^8.13.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.6.0"
  }
}
